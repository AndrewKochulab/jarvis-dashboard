{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Jarvis",
  "version": "1.0.0",
  "identifier": "com.jarvis.dashboard",
  "build": {
    "beforeDevCommand": "/usr/bin/python3 -m http.server 1420 --directory web",
    "frontendDist": "../web",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "icon": [
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Jarvis",
        "width": 1200,
        "height": 900,
        "minWidth": 600,
        "minHeight": 500,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "useHttpsScheme": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: ws: wss: http: https:; media-src 'self' blob: mediastream:; img-src 'self' data: blob:"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
